PORT=8787
NODE_ENV=development
APP_ORIGIN=http://localhost:8787
APP_SECRET=replace-with-a-long-random-secret
DATA_DIR=./data
# Leave empty for local JSON storage. Set by Render Postgres in production.
DATABASE_URL=

# Live-capable by default. Orders still require a connected user Bitget key,
# an agent TRADE decision, an allowed symbol, and a notional below the cap.
LIVE_TRADING_ENABLED=true
LIVE_MAX_NOTIONAL_USDT=25
LIVE_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Bitget API credentials. Use a restricted futures key with IP allowlist if possible.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_BASE_URL=https://api.bitget.com
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_MODE=isolated
BITGET_MARGIN_COIN=USDT

# Optional Bitget AI docs/MCP endpoint. The app checks status without storing workspace context.
BITGET_MCP_URL=https://bitget-ai.gitbook.io/hackathon/~gitbook/mcp
